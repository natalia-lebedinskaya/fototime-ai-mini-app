  function classifyUser(text) {
    const low = String(text || '').toLowerCase();
    if (
      low.includes('tg-') ||
      low.includes('telegram') ||
      low.includes('@') ||
      /id[:\s]*\d{5,}/i.test(text || '')
    ) {
      return { label: 'Telegram', cls: 'telegram' };
    }
    return { label: 'Гость', cls: 'guest' };
  }

  function extractUserKey(card) {
    const candidates = qsa('*', card)
      .map((el) => txt(el))
      .filter(Boolean);

    const priority = candidates.find((t) =>
      /^tg-\d+$/i.test(t) ||
      /^@\S+$/i.test(t) ||
      /^local-demo-user$/i.test(t) ||
      /^guest[-_]/i.test(t) ||
      /^local[-_]/i.test(t)
    );
    if (priority) return priority;

    const candidate = candidates.find((t) =>
      t.length >= 3 &&
      t.length <= 80 &&
      !t.includes('Баланс') &&
      !t.includes('Сохранить') &&
      !t.includes('Чек') &&
      !t.includes('Оплата')
    );
    return candidate ? candidate.trim() : '';
  }

  function getSeenUsers() {
    const raw = storageGet(SEEN_USERS_KEY, '[]');
    try {
      const arr = JSON.parse(raw);
      return Array.isArray(arr) ? arr : [];
    } catch (_) {
      return [];
    }
  }

  function setSeenUsers(arr) {
    storageSet(SEEN_USERS_KEY, JSON.stringify(Array.from(new Set(arr)).slice(-500)));
  }

  function polishAdminUsers() {
    const adminRoot = qsa('section,article,div').find((el) => {
      const t = txt(el);
      return t.includes('Пользователи') && t.includes('Баланс');
    });

    if (!adminRoot) return;

    const cards = qsa('section,article,div', adminRoot).filter((el) => {
      const t = txt(el);
      return t.includes('Баланс') && t.includes('Сохранить');
    });

    if (!cards.length) return;

    const seen = getSeenUsers();
    const bootstrapped = storageGet(SEEN_USERS_BOOT_KEY, '') === '1';
    const nowSeen = new Set(seen);

    cards.forEach((card) => {
      const key = extractUserKey(card);
      if (!key) return;

      const cardText = txt(card);
      const userType = classifyUser(cardText);

      let meta = qs('.ft-admin-user-meta', card);
      if (!meta) {
        meta = document.createElement('div');
        meta.className = 'ft-admin-user-meta';
        card.insertAdjacentElement('afterbegin', meta);
      } else {
        meta.innerHTML = '';
      }

      const typeChip = document.createElement('span');
      typeChip.className = `ft-admin-user-chip ft-admin-user-chip--${userType.cls}`;
      typeChip.textContent = userType.label;
      meta.appendChild(typeChip);

      const idChip = document.createElement('span');
      idChip.className = 'ft-admin-user-chip';
      idChip.textContent = key.length > 22 ? key.slice(0, 22) + '…' : key;
      meta.appendChild(idChip);

      const isNew = bootstrapped ? !nowSeen.has(key) : false;
      if (isNew) {
        const newChip = document.createElement('span');
        newChip.className = 'ft-admin-user-chip ft-admin-user-chip--new';
        newChip.textContent = 'NEW';
        meta.appendChild(newChip);
      }

      let note = qs('.ft-admin-user-note', card);
      if (!note) {
        note = document.createElement('div');
        note.className = 'ft-admin-user-note';
        meta.insertAdjacentElement('afterend', note);
      }

      note.textContent =
        userType.label === 'Telegram'
          ? 'Авторизованный пользователь. История и функции привязаны к Telegram.'
          : 'Гостевой пользователь. Данные хранятся локально до авторизации.';

      nowSeen.add(key);
    });

    if (!bootstrapped) {
      storageSet(SEEN_USERS_BOOT_KEY, '1');
    }
    setSeenUsers(Array.from(nowSeen));
  }

  function tick() {
    injectStyles();
    polishAdminUsers();
    ensureBuildFooter();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', tick);
  } else {
    tick();
  }

  window.addEventListener('load', tick);
  window.addEventListener('hashchange', tick);

  const observer = new MutationObserver(() => {
    clearTimeout(window.__ftPolishAdminFooterTick);
    window.__ftPolishAdminFooterTick = setTimeout(tick, 120);
  });

  observer.observe(document.documentElement, {
    childList: true,
    subtree: true
  });
})();
/* FT_POLISH_ADMIN_FOOTER_V1_END */


/* FT_ADMIN_USER_RENAME_V1_START */
(() => {
  if (window.__FT_ADMIN_USER_RENAME_V1__) return;
  window.__FT_ADMIN_USER_RENAME_V1__ = true;

  const USER_ALIAS_KEY = 'ft_admin_user_aliases_v1';

  function qs(sel, root = document) {
    return root.querySelector(sel);
  }

  function qsa(sel, root = document) {
    return Array.from(root.querySelectorAll(sel));
  }

  function txt(el) {
    return String(el?.textContent || '').replace(/\s+/g, ' ').trim();
  }

  function storageGet(key, fallback = '') {
    try {
      return localStorage.getItem(key) || fallback;
    } catch (_) {
      return fallback;
    }
  }

  function storageSet(key, value) {
    try {
      localStorage.setItem(key, value);
    } catch (_) {}
  }

  function getAliases() {
    try {
      const raw = storageGet(USER_ALIAS_KEY, '{}');
      const data = JSON.parse(raw);
      return data && typeof data === 'object' ? data : {};
    } catch (_) {
      return {};
    }
  }

  function setAliases(next) {
    storageSet(USER_ALIAS_KEY, JSON.stringify(next || {}));
  }

  function getAlias(key) {
    const aliases = getAliases();
    return String(aliases[key] || '').trim();
  }

  function setAlias(key, value) {
    const aliases = getAliases();
    if (value && value.trim()) {
      aliases[key] = value.trim();
    } else {
      delete aliases[key];
    }
    setAliases(aliases);
  }

  function injectStyles() {
    if (document.getElementById('ft-admin-user-rename-v1-style')) return;

    const style = document.createElement('style');
    style.id = 'ft-admin-user-rename-v1-style';
    style.textContent = `
      .ft-admin-user-title {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 8px;
        margin: 4px 0 10px;
      }

      .ft-admin-user-name {
        font-size: 20px;
        line-height: 1.15;
        font-weight: 900;
        letter-spacing: -.02em;
      }

      .ft-admin-user-name.is-alias {
        color: rgba(255,255,255,.98);
      }

      .ft-admin-user-source {
        font-size: 12px;
        line-height: 1.3;
        font-weight: 800;
        opacity: .72;
      }

      .ft-admin-user-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 8px 0 12px;
      }

      .ft-admin-user-mini-btn {
        appearance: none;
        border: 1px solid rgba(255,255,255,.12);
        background: rgba(255,255,255,.08);
        color: rgba(255,255,255,.96);
        border-radius: 999px;
        padding: 7px 12px;
        font-size: 12px;
        line-height: 1;
        font-weight: 900;
        cursor: pointer;
        transition: transform .12s ease, filter .12s ease, background .12s ease;
      }

      .ft-admin-user-mini-btn:hover {
        transform: translateY(-1px);
        filter: brightness(1.04);
      }

      .ft-admin-user-mini-btn--accent {
        background: rgba(185,255,85,.16);
        border-color: rgba(185,255,85,.32);
      }
    `;
    document.head.appendChild(style);
  }

  function extractUserKey(card) {
    const candidates = qsa('*', card)
      .map((el) => txt(el))
      .filter(Boolean);

    const priority = candidates.find((t) =>
      /^tg-\d+$/i.test(t) ||
      /^@\S+$/i.test(t) ||
      /^local-demo-user$/i.test(t) ||
      /^guest[-_]/i.test(t) ||
      /^local[-_]/i.test(t)
    );
    if (priority) return priority;

    const candidate = candidates.find((t) =>
      t.length >= 3 &&
      t.length <= 80 &&
      !t.includes('Баланс') &&
      !t.includes('Сохранить') &&
      !t.includes('Чек') &&
      !t.includes('Оплата') &&
      !t.includes('Гость') &&
      !t.includes('Telegram') &&
      !t.includes('NEW')
    );
    return candidate ? candidate.trim() : '';
  }

  function classifyUser(text) {
    const low = String(text || '').toLowerCase();
    if (
      low.includes('tg-') ||
      low.includes('telegram') ||
      low.includes('@') ||
      /id[:\s]*\d{5,}/i.test(text || '')
    ) {
      return { label: 'Telegram', cls: 'telegram' };
    }
    return { label: 'Гость', cls: 'guest' };
  }

  function findAdminUserCards() {
    const adminRoot = qsa('section,article,div').find((el) => {
      const t = txt(el);
      return t.includes('Пользователи') && t.includes('Баланс');
    });

    if (!adminRoot) return [];

    return qsa('section,article,div', adminRoot).filter((el) => {
      const t = txt(el);
      return t.includes('Баланс') && t.includes('Сохранить');
    });
  }

  function openRenamePrompt(key, currentAlias, fallbackName) {
    const next = window.prompt(
      'Введите имя для пользователя в админ-консоли',
      currentAlias || fallbackName || key
    );
    if (next === null) return false;
    setAlias(key, next);
    return true;
  }

  function resetAlias(key) {
    setAlias(key, '');
  }

  function ensureUserTitle(card, key, userType) {
    let title = qs('.ft-admin-user-title', card);
    if (!title) {
      title = document.createElement('div');
      title.className = 'ft-admin-user-title';
      const meta = qs('.ft-admin-user-meta', card);
      if (meta) {
        meta.insertAdjacentElement('afterend', title);
      } else {
        card.insertAdjacentElement('afterbegin', title);
      }
    } else {
      title.innerHTML = '';
    }

    const alias = getAlias(key);
    const shownName = alias || key;
    const nameEl = document.createElement('div');
    nameEl.className = 'ft-admin-user-name' + (alias ? ' is-alias' : '');
    nameEl.textContent = shownName;

    const sourceEl = document.createElement('div');
    sourceEl.className = 'ft-admin-user-source';
    sourceEl.textContent = alias
      ? `Исходное имя: ${key} · ${userType.label}`
      : `Системное имя: ${key} · ${userType.label}`;

    title.appendChild(nameEl);
    title.appendChild(sourceEl);
  }

  function ensureUserActions(card, key) {
    let actions = qs('.ft-admin-user-actions', card);
    if (!actions) {
      actions = document.createElement('div');
      actions.className = 'ft-admin-user-actions';
      const title = qs('.ft-admin-user-title', card);
      if (title) {
        title.insertAdjacentElement('afterend', actions);
      } else {
        card.insertAdjacentElement('afterbegin', actions);
      }
    } else {
      actions.innerHTML = '';
    }

    const renameBtn = document.createElement('button');
    renameBtn.type = 'button';
    renameBtn.className = 'ft-admin-user-mini-btn ft-admin-user-mini-btn--accent';
    renameBtn.textContent = 'Переименовать';
    renameBtn.addEventListener('click', () => {
      const alias = getAlias(key);
      if (openRenamePrompt(key, alias, key)) {
        polishAdminUsersRename();
      }
    });

    const resetBtn = document.createElement('button');
    resetBtn.type = 'button';
    resetBtn.className = 'ft-admin-user-mini-btn';
    resetBtn.textContent = 'Сбросить имя';
    resetBtn.addEventListener('click', () => {
      resetAlias(key);
      polishAdminUsersRename();
    });

    actions.appendChild(renameBtn);
    actions.appendChild(resetBtn);
  }

  function removeDuplicateRawName(card, key) {
    qsa('*', card).forEach((el) => {
      if (
        !el.closest('.ft-admin-user-title') &&
        !el.closest('.ft-admin-user-meta') &&
        !el.closest('.ft-admin-user-actions')
      ) {
        const value = txt(el);
        if (value === key) {
          el.style.display = 'none';
        }
      }
    });
  }

  function polishAdminUsersRename() {
    injectStyles();

    const cards = findAdminUserCards();
    if (!cards.length) return;

    cards.forEach((card) => {
      const key = extractUserKey(card);
      if (!key) return;

      const userType = classifyUser(txt(card));

      ensureUserTitle(card, key, userType);
      ensureUserActions(card, key);
      removeDuplicateRawName(card, key);
    });
  }

  function tick() {
    polishAdminUsersRename();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', tick);
  } else {
    tick();
  }

  window.addEventListener('load', tick);
  window.addEventListener('hashchange', tick);

  const observer = new MutationObserver(() => {
    clearTimeout(window.__ftAdminUserRenameTick);
    window.__ftAdminUserRenameTick = setTimeout(tick, 120);
  });

  observer.observe(document.documentElement, {
    childList: true,
    subtree: true
  });
})();
/* FT_ADMIN_USER_RENAME_V1_END */

