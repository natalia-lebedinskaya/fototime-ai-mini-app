

/* FT_CLIENT_VERSION_BADGE_V1 */
window.FT_DEPLOY_VERSION = "fototime-prod-20260611-140000-v27-clean-stable-front";
console.info("[FOTOTIME DEPLOY VERSION]", window.FT_DEPLOY_VERSION);

