  function bindSecretAdminTrigger() {
    const candidates = qsa('div,span,h1,h2,h3,p,a,button').filter((el) => {
      const t = txt(el);
      return t === 'FOT AI' || t === 'FOTOTIMEAI' || t === 'FOTOTIME323';
    });

    candidates.forEach((el) => {
      if (el.dataset.ftAdminSecretBound === '1') return;
      el.dataset.ftAdminSecretBound = '1';

      let taps = 0;
      let timer = null;

      el.addEventListener('click', () => {
        taps += 1;
        clearTimeout(timer);
        timer = setTimeout(() => { taps = 0; }, 1400);

        if (taps >= 5) {
          taps = 0;
          tryUnlockAdmin();
