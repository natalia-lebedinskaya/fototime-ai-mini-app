:root {
  --bg: #07070d;
  --card: rgba(255, 255, 255, 0.08);
  --card-strong: rgba(255, 255, 255, 0.12);
  --border: rgba(255, 255, 255, 0.14);
  --text: #ffffff;
  --muted: rgba(255, 255, 255, 0.68);
  --accent: #b8ff1f;
  --accent-blue: #00d7ff;
  --error: #ff5c7a;
  --success: #43f5a4;
  --warning: #ffd166;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-height: 100vh;
  color: var(--text);
  font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  background:
    radial-gradient(circle at 15% 10%, rgba(184, 255, 31, 0.2), transparent 28%),
    radial-gradient(circle at 85% 0%, rgba(0, 215, 255, 0.16), transparent 30%),
    linear-gradient(180deg, #07070d 0%, #11111d 100%);
}

button,
input {
  font-family: inherit;
}

.app {
  width: min(100%, 860px);
  margin: 0 auto;
  padding: 24px 16px 48px;
}

.hero {
  padding: 28px 4px 18px;
}

.brand-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.brand-badge,
.status-badge {
  display: inline-flex;
  align-items: center;
  min-height: 34px;
  padding: 7px 12px;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.08);
  color: var(--muted);
  font-size: 12px;
  font-family: "Unbounded", "Inter", sans-serif;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.status-badge.active {
  color: #101010;
  background: var(--accent);
}

.status-badge.error {
  color: #ffffff;
  background: var(--error);
}

.hero h1 {
  margin: 34px 0 0;
  font-family: "Unbounded", "Inter", sans-serif;
  font-size: clamp(40px, 12vw, 76px);
  line-height: 0.9;
  letter-spacing: -0.08em;
  text-transform: uppercase;
  text-shadow: 3px 0 rgba(0, 215, 255, 0.45), -3px 0 rgba(255, 92, 122, 0.38);
}

.hero p {
  max-width: 640px;
  margin: 18px 0 0;
  color: var(--muted);
  font-size: 17px;
  line-height: 1.5;
}

.card,
.state-card {
  margin-top: 18px;
  padding: 22px;
  border: 1px solid var(--border);
  border-radius: 28px;
  background: var(--card);
  box-shadow: 0 24px 80px rgba(0, 0, 0, 0.26);
  backdrop-filter: blur(18px);
}

.section-header {
  display: flex;
  gap: 12px;
  align-items: flex-start;
  margin-bottom: 18px;
}

.step {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 40px;
  height: 40px;
  border-radius: 14px;
  color: #101010;
  background: linear-gradient(135deg, var(--accent), var(--accent-blue));
  font-size: 13px;
  font-weight: 900;
}

h2 {
  margin: 0;
  font-family: "Unbounded", "Inter", sans-serif;
  font-size: 22px;
  letter-spacing: -0.04em;
}

.section-subtitle {
  margin: 6px 0 0;
  color: var(--muted);
  font-size: 14px;
}

.chips-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 11px;
}

.participant-chip {
  min-height: 52px;
  border: 1px solid var(--border);
  border-radius: 18px;
  color: var(--text);
  background: rgba(255, 255, 255, 0.08);
  font-size: 15px;
  font-weight: 800;
  cursor: pointer;
}

.participant-chip.selected {
  color: #101010;
  background: var(--accent);
}

.styles-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.style-card {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 10px;
  border: 1px solid var(--border);
  border-radius: 24px;
  color: var(--text);
  background: rgba(255, 255, 255, 0.08);
  text-align: left;
  cursor: pointer;
  transition: 0.2s ease;
}

.style-card.selected {
  border-color: var(--accent);
  box-shadow: 0 0 0 2px rgba(184, 255, 31, 0.32);
}

.style-preview {
  width: 100%;
  aspect-ratio: 3 / 4;
  border-radius: 18px;
  object-fit: cover;
  background: rgba(255, 255, 255, 0.08);
}

.style-name {
  font-size: 14px;
  font-weight: 800;
  line-height: 1.25;
}

.style-price {
  position: absolute;
  top: 16px;
  right: 16px;
  padding: 6px 9px;
  border-radius: 999px;
  color: #101010;
  background: var(--accent);
  font-size: 12px;
  font-weight: 900;
}

.upload-zone {
  display: flex;
  flex-direction: column;
  gap: 6px;
  width: 100%;
  margin-bottom: 16px;
  padding: 22px;
  border: 1px dashed rgba(255, 255, 255, 0.32);
  border-radius: 22px;
  background: rgba(255, 255, 255, 0.06);
  cursor: pointer;
}

.upload-title {
  font-size: 18px;
  font-weight: 900;
}

.upload-description {
  color: var(--muted);
  font-size: 14px;
}

.hidden-input,
.hidden {
  display: none;
}

.primary-button,
.secondary-button {
  width: 100%;
  min-height: 58px;
  border: none;
  border-radius: 20px;
  color: #101010;
  background: var(--accent);
  font-size: 18px;
  font-weight: 900;
  cursor: pointer;
  transition: 0.2s ease;
}

.primary-button:disabled {
  cursor: not-allowed;
  opacity: 0.38;
}

.secondary-button {
  margin-top: 14px;
  color: var(--text);
  background: rgba(255, 255, 255, 0.14);
}

.message {
  min-height: 22px;
  margin: 14px 0 0;
  font-size: 14px;
  line-height: 1.4;
}

.message.error {
  color: var(--error);
}

.message.success {
  color: var(--success);
}

.message.info {
  color: var(--warning);
}

.empty-state {
  padding: 18px;
  border: 1px dashed var(--border);
  border-radius: 18px;
  color: var(--muted);
  background: rgba(255, 255, 255, 0.06);
}

.result-card {
  border-color: rgba(67, 245, 164, 0.36);
}

.result-image {
  width: 100%;
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.08);
}

@media (max-width: 540px) {
  .app {
    padding: 18px 12px 36px;
  }

  .chips-grid,
  .styles-grid {
    grid-template-columns: 1fr;
  }

  .card,
  .state-card {
    padding: 18px;
    border-radius: 24px;
  }
}

.result-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10px;
  margin-top: 16px;
}

.contacts-card {
  margin-top: 18px;
}

.contacts-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 11px;
}

.contacts-grid a {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 52px;
  border: 1px solid var(--border);
  border-radius: 18px;
  color: var(--text);
  background: rgba(255, 255, 255, 0.08);
  font-size: 15px;
  font-weight: 900;
  text-decoration: none;
  transition: 0.2s ease;
}

.contacts-grid a:hover {
  transform: translateY(-2px);
  border-color: rgba(255, 255, 255, 0.34);
}

@media (max-width: 540px) {
  .contacts-grid {
    grid-template-columns: 1fr;
  }
}

.history-card {
  margin-top: 18px;
}

.history-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
}

.history-item {
  overflow: hidden;
  border: 1px solid var(--border);
  border-radius: 22px;
  background: rgba(255, 255, 255, 0.07);
}

.history-item img {
  display: block;
  width: 100%;
  aspect-ratio: 3 / 4;
  object-fit: cover;
  background: rgba(0, 0, 0, 0.24);
}

.history-item-content {
  display: grid;
  gap: 6px;
  padding: 12px;
}

.history-item-content strong {
  color: var(--text);
  font-size: 13px;
  line-height: 1.2;
}

.history-item-content span {
  color: var(--muted);
  font-size: 12px;
}

.history-download-button {
  min-height: 38px;
  border: 1px solid var(--border);
  border-radius: 13px;
  color: var(--text);
  background: rgba(255, 255, 255, 0.09);
  font: inherit;
  font-size: 12px;
  font-weight: 900;
  cursor: pointer;
}

.history-download-button:hover {
  border-color: rgba(255, 255, 255, 0.34);
}

.history-clear-button {
  width: 100%;
.history-card .secondary-button {
  margin-top: 14px;
}

@media (max-width: 720px) {
  .history-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 420px) {
  .history-grid {
    grid-template-columns: 1fr;
  }
}

.history-clear-button {
  width: 100%;
  margin-top: 14px;
}

body::before {
  content: "";
  position: fixed;
  inset: -40%;
  z-index: -1;
  background:
    radial-gradient(circle at 20% 20%, rgba(184, 255, 31, 0.18), transparent 28%),
    radial-gradient(circle at 80% 10%, rgba(0, 215, 255, 0.16), transparent 30%),
    radial-gradient(circle at 50% 80%, rgba(255, 92, 122, 0.12), transparent 32%);
  filter: blur(10px);
  animation: backgroundFloat 18s ease-in-out infinite alternate;
  pointer-events: none;
}

@keyframes backgroundFloat {
  0% {
    transform: translate3d(-2%, -1%, 0) rotate(0deg) scale(1);
  }

  50% {
    transform: translate3d(2%, 1%, 0) rotate(8deg) scale(1.04);
  }

  100% {
    transform: translate3d(1%, -2%, 0) rotate(-6deg) scale(1.02);
  }
}

@media (prefers-reduced-motion: reduce) {
  body::before {
    animation: none;
  }
}

.app::before {
  content: "";
  position: fixed;
  width: 420px;
  height: 420px;
  top: 8%;
  left: -120px;
  z-index: -1;
  border-radius: 999px;
  background: rgba(184, 255, 31, 0.18);
  filter: blur(70px);
  animation: neonBlobLeft 14s ease-in-out infinite alternate;
  pointer-events: none;
}

.app::after {
  content: "";
  position: fixed;
  width: 460px;
  height: 460px;
  right: -140px;
  bottom: 12%;
  z-index: -1;
  border-radius: 999px;
  background: rgba(0, 215, 255, 0.16);
  filter: blur(80px);
  animation: neonBlobRight 16s ease-in-out infinite alternate;
  pointer-events: none;
}

@keyframes neonBlobLeft {
  0% {
    transform: translate3d(0, 0, 0) scale(1);
  }

  100% {
    transform: translate3d(80px, 120px, 0) scale(1.18);
  }
}

@keyframes neonBlobRight {
  0% {
    transform: translate3d(0, 0, 0) scale(1);
  }

  100% {
    transform: translate3d(-90px, -90px, 0) scale(1.12);
  }
}

@media (prefers-reduced-motion: reduce) {
  .app::before,
  .app::after {
    animation: none;
  }
}

/* Чтобы при выборе фильтров визуально не прыгал/не менялся фон секции */
.providers-filters,
.provider-filter,
.provider-filter.active,
.provider-filter:hover,
.provider-filter:focus-within {
  box-shadow: none;
  backdrop-filter: none;
}

.provider-filter {
  min-height: 46px;
  padding: 11px 16px;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.055);
  border: 1px solid rgba(255, 255, 255, 0.14);
}

.provider-filter:hover {
  background: rgba(255, 255, 255, 0.075);
  border-color: rgba(180, 255, 75, 0.48);
}

.provider-filter.active {
  background: rgba(180, 255, 75, 0.14);
  border-color: rgba(180, 255, 75, 0.72);
}

/* Увеличиваем чекбоксы */
.provider-filter input {
  width: 20px;
  height: 20px;
  min-width: 20px;
  accent-color: #b4ff4b;
  cursor: pointer;
}

.provider-filter span {
  font-size: 14px;
  font-weight: 800;
}

/* Поиск в стиле проекта */
.styles-toolbar {
  margin: 18px 0 16px;
}

.styles-search {
  width: 100%;
  min-height: 62px;
  padding: 0 20px;
  border-radius: 22px;
  border: 1px solid var(--border, rgba(255, 255, 255, 0.16));
  background: rgba(255, 255, 255, 0.055);
  box-shadow: none;
}

.styles-search:hover {
  border-color: rgba(180, 255, 75, 0.45);
  background: rgba(255, 255, 255, 0.07);
}

.styles-search:focus-within {
  border-color: rgba(180, 255, 75, 0.85);
  background: rgba(255, 255, 255, 0.075);
  box-shadow: 0 0 0 3px rgba(180, 255, 75, 0.1);
}

.styles-search-icon {
  width: 28px;
  height: 28px;
  font-size: 24px;
  color: #b4ff4b;
  font-weight: 900;
}

.styles-search input {
  height: 58px;
  font-family: inherit;
  font-size: 16px;
  font-weight: 800;
  letter-spacing: -0.01em;
  color: #ffffff;
}

.styles-search input::placeholder {
  font-family: inherit;
  font-size: 16px;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.58);
  letter-spacing: -0.01em;
}

/* На мобильном делаем каталог ниже, но всё равно скроллируемым */
@media (max-width: 720px) {
  .styles-grid {
    max-height: 620px;
  }

  .styles-search {
    min-height: 58px;
    padding: 0 16px;
  }

  .styles-search input,
  .styles-search input::placeholder {
    font-size: 14px;
  }

  .provider-filter {
    min-height: 44px;
    padding: 10px 14px;
  }

  .provider-filter input {
    width: 19px;
    height: 19px;
    min-width: 19px;
  }
}

/* Styles catalog: horizontal scroll, clean search/filter panel, no price */
.card:has(#stylesGrid) {
  overflow: hidden;
}

.styles-filter-panel {
  margin: 18px 0 18px;
  border-radius: 22px;
  border: 1px solid rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.045);
  overflow: hidden;
}

.styles-filter-panel summary {
  min-height: 58px;
  display: flex;
  align-items: center;
  padding: 0 18px;
  cursor: pointer;
  list-style: none;
  color: #ffffff;
  font-family: inherit;
  font-size: 16px;
  font-weight: 900;
  letter-spacing: -0.01em;
}

.styles-filter-panel summary::-webkit-details-marker {
  display: none;
}

.styles-filter-panel summary::after {
  content: "Открыть";
  margin-left: auto;
  padding: 8px 12px;
  border-radius: 999px;
  background: rgba(180, 255, 75, 0.14);
  border: 1px solid rgba(180, 255, 75, 0.35);
  color: #dfffaa;
  font-size: 12px;
  font-weight: 900;
}

.styles-filter-panel[open] summary::after {
  content: "Скрыть";
}

.styles-toolbar {
  width: 100%;
  margin: 0;
  padding: 0 18px 14px;
  box-sizing: border-box;
}

.styles-search {
  box-sizing: border-box;
  width: 100%;
  min-height: 58px;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 0 18px;
  border-radius: 18px;
  border: 1px solid rgba(180, 255, 75, 0.38);
  background: rgba(255, 255, 255, 0.06);
  box-shadow: none;
}

.styles-search:focus-within {
  border-color: rgba(180, 255, 75, 0.85);
  background: rgba(255, 255, 255, 0.075);
  box-shadow: 0 0 0 3px rgba(180, 255, 75, 0.1);
}

.styles-search-icon {
  width: 26px;
  height: 26px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #b4ff4b;
  font-size: 23px;
  font-weight: 900;
  flex-shrink: 0;
}

.styles-search input {
  width: 100%;
  height: 54px;
  min-width: 0;
  border: 0;
  outline: none;
  background: transparent;
  color: #ffffff;
  font-family: inherit;
  font-size: 15px;
  font-weight: 800;
  letter-spacing: -0.01em;
}

.styles-search input::placeholder {
  color: rgba(255, 255, 255, 0.58);
  font-family: inherit;
  font-size: 15px;
  font-weight: 800;
}

.providers-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  padding: 0 18px 18px;
  margin: 0;
}

.provider-filter {
  min-height: 48px;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 11px 16px;
  border-radius: 18px;
  border: 1px solid rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.055);
  cursor: pointer;
  transition: 0.18s ease;
  user-select: none;
  box-shadow: none;
  backdrop-filter: none;
}

.provider-filter:hover {
  border-color: rgba(180, 255, 75, 0.48);
  background: rgba(255, 255, 255, 0.075);
}

.provider-filter.active {
  border-color: rgba(180, 255, 75, 0.72);
  background: rgba(180, 255, 75, 0.14);
}

.provider-filter input {
  width: 22px;
  height: 22px;
  min-width: 22px;
  margin: 0;
  accent-color: #b4ff4b;
  cursor: pointer;
}

.provider-filter span {
  color: #ffffff;
  font-size: 14px;
  font-weight: 900;
  line-height: 1;
}

/* Horizontal style carousel */
.styles-grid {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: minmax(210px, 1fr);
  grid-template-columns: unset;
  gap: 16px;
  overflow-x: auto;
  overflow-y: hidden;
  max-height: none;
  padding: 0 4px 18px;
  scroll-snap-type: x mandatory;
  scrollbar-width: thin;
  scrollbar-color: rgba(180, 255, 75, 0.65) rgba(255, 255, 255, 0.08);
}

.styles-grid::-webkit-scrollbar {
  height: 10px;
}

.styles-grid::-webkit-scrollbar-track {
  background: rgba(255, 255, 255, 0.07);
  border-radius: 999px;
}

.styles-grid::-webkit-scrollbar-thumb {
  background: rgba(180, 255, 75, 0.65);
  border-radius: 999px;
}

.styles-grid::-webkit-scrollbar-thumb:hover {
  background: rgba(180, 255, 75, 0.9);
}

.style-card {
  scroll-snap-align: start;
  min-width: 0;
}

.style-price {
  display: none !important;
}

.style-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 12px;
}

.style-badge {
  display: inline-flex;
  align-items: center;
  padding: 6px 10px;
  border-radius: 999px;
  background: rgba(180, 255, 75, 0.13);
  border: 1px solid rgba(180, 255, 75, 0.3);
  color: #dfffaa;
  font-size: 12px;
  font-weight: 800;
  line-height: 1;
}

.style-preview {
  display: block;
  width: 100%;
  aspect-ratio: 4 / 3;
  object-fit: cover;
  border-radius: 16px;
  margin-bottom: 12px;
  background: rgba(0, 0, 0, 0.24);
}

/* Wider screens: around 6 cards visible */
@media (min-width: 1100px) {
  .styles-grid {
    grid-auto-columns: calc((100% - 80px) / 6);
  }
}

/* Medium screens: around 3 cards visible */
@media (min-width: 721px) and (max-width: 1099px) {
  .styles-grid {
    grid-auto-columns: calc((100% - 32px) / 3);
  }
}

/* Mobile: around 1.35 cards visible, swipe-friendly */
@media (max-width: 720px) {
  .styles-filter-panel summary {
    min-height: 56px;
    padding: 0 15px;
    font-size: 15px;
  }

  .styles-toolbar {
    padding: 0 14px 14px;
  }

  .styles-search {
    min-height: 56px;
    padding: 0 15px;
  }

  .styles-search input,
  .styles-search input::placeholder {
    font-size: 14px;
  }

  .providers-filters {
    padding: 0 14px 16px;
  }

  .provider-filter {
    min-height: 46px;
    padding: 10px 14px;
  }

  .provider-filter input {
    width: 21px;
    height: 21px;
    min-width: 21px;
  }

  .styles-grid {
    grid-auto-columns: 74%;
    gap: 14px;
  }
}

/* Performance: компактный вывод каталога стилей */
.styles-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.styles-load-more-button {
  width: 100%;
  margin-top: 16px;
  min-height: 48px;
  border: 1px solid var(--border);
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.08);
  color: var(--text);
  font: inherit;
  font-weight: 800;
  cursor: pointer;
}

.styles-load-more-button:hover {
  border-color: rgba(169, 255, 0, 0.55);
  background: rgba(169, 255, 0, 0.1);
}

@media (max-width: 720px) {
  .styles-grid {
    display: flex;
    overflow-x: auto;
    gap: 14px;
    padding-bottom: 10px;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
  }

  .style-card {
    flex: 0 0 78%;
    scroll-snap-align: start;
  }

  .styles-grid::-webkit-scrollbar {
    height: 6px;
  }

  .styles-grid::-webkit-scrollbar-thumb {
    background: rgba(169, 255, 0, 0.35);
    border-radius: 999px;
  }
}

.styles-load-more-button {
  width: 100%;
  min-height: 52px;
  margin-top: 16px;
