  font-size: 58px !important;
  line-height: .94 !important;
}

html[data-ft-compact="1"] h2 {
  font-size: 30px !important;
}

html[data-ft-compact="1"] h3 {
  font-size: 22px !important;
}

html[data-ft-compact="1"] button,
html[data-ft-compact="1"] input,
html[data-ft-compact="1"] select,
html[data-ft-compact="1"] textarea {
  font-size: 14px !important;
}

.ft-v31-avatar {
  width: 52px;
  height: 52px;
  min-width: 52px;
  border: 0;
  border-radius: 18px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  cursor: pointer;
  margin-right: 10px;
  background: linear-gradient(135deg, #d8ff24 0%, #72e7d8 100%);
  box-shadow: 0 10px 24px rgba(120, 255, 160, .16);
  animation: ftV31AvatarFloat 4.8s ease-in-out infinite;
  isolation: isolate;
}

.ft-v31-avatar[data-gradient="ocean"] { background: linear-gradient(135deg, #7fdcff 0%, #6f8cff 100%); }
.ft-v31-avatar[data-gradient="sunset"] { background: linear-gradient(135deg, #ffd84b 0%, #ff7ea8 100%); }
.ft-v31-avatar[data-gradient="violet"] { background: linear-gradient(135deg, #d7a7ff 0%, #7ddcff 100%); }

.ft-v31-avatar-photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.ft-v31-avatar-emoji {
  font-size: 25px;
  line-height: 1;
}

@keyframes ftV31AvatarFloat {
  0%,100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-1px) scale(1.03); }
}

.ft-v31-entry-overlay {
  position: fixed;
  inset: 0;
