/* FT_V31_UX_START */
:root {
  --ft-v31-scale: 0.86;
}

#ftDeployVersionBadge,
.ft-deploy-badge,
[class*="deploy-version"],
[class*="version-badge"] {
  display: none !important;
}

html[data-ft-compact="1"] body {
  font-size: 14px !important;
}

