NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Comma-separated origins. Leave empty for same-origin local development.
CORS_ORIGINS=

# External image-generation adapter. Configure these values only on the server.
IMAGE_PROVIDER_BASE_URL=
IMAGE_PROVIDER_API_KEY=
IMAGE_PROVIDER_POLL_INTERVAL_MS=3000
IMAGE_PROVIDER_MAX_ATTEMPTS=40
IMAGE_PROVIDER_REQUEST_TIMEOUT_MS=30000
IMAGE_PROVIDER_DRY_RUN=false

# Persistent identity storage.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
FOTOTIME_SESSION_SECRET=
ALLOW_LOCAL_AUTH=false

# Optional Telegram Mini App identity and operator notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
ADMIN_NOTIFICATION_BOT_TOKEN=
ADMIN_NOTIFICATION_CHAT_ID=

# Operator access. Use long, unique values and configure them in the hosting platform.
ADMIN_PIN=
ADMIN_USER_IDS=
ADMIN_USERNAMES=
ADMIN_USER_EMAILS=
