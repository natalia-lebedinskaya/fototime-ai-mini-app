PORT=3000

GENERATION_PROVIDER=mock

CYBERPHOTOBOOTH_API_URL=https://api.cyberphotobooth.ru/api
CYBERPHOTOBOOTH_API_KEY=
CYBERPHOTOBOOTH_STYLE=1029

# Live/default mode:
CYBERPHOTOBOOTH_MODE=style_sdxl_zero

# Demo switch for future integration.
# If CyberPhotoBooth provides a separate demo mode value, set CYBERPHOTOBOOTH_MODE to that value.
CYBERPHOTOBOOTH_DEMO=false

CYBERPHOTOBOOTH_POLL_INTERVAL_MS=3000
CYBERPHOTOBOOTH_MAX_ATTEMPTS=60
CYBERPHOTOBOOTH_DRY_RUN=false

ADMIN_TELEGRAM_IDS=local-demo-user
