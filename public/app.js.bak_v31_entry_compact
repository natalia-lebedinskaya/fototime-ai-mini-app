  function hideStaleHomeResult() {
    const shouldShow = sessionStorage.getItem(HOME_RESULT_FLAG) === '1';
    qsa('div,section,article').forEach((el) => {
      const t = textOf(el);
      if (t.includes('Результат') && t.includes('Скачать изображение') && !shouldShow) {
        el.style.display = 'none';
      }
    });

    const createBtn = qsa('button').find((el) => /создать ai-фото/i.test(textOf(el)));
    if (createBtn && !createBtn.dataset.ftV31Bound) {
      createBtn.dataset.ftV31Bound = '1';
      createBtn.addEventListener('click', () => {
        sessionStorage.setItem(HOME_RESULT_FLAG, '1');
      });
    }
  }

  function markStyleCardsAndCompactView() {
    const cards = qsa('div,article,section').filter((el) => {
      if (el.classList.contains('ft-v31-style-card')) return false;
      const hasImg = !!el.querySelector('img');
      const t = textOf(el);
      const providerHit = /sdxl|flux\.2|nano banana|замена головы/i.test(t);
      return hasImg && providerHit;
    });

    cards.forEach((card) => card.classList.add('ft-v31-style-card'));

    const catalog = cards[0]?.parentElement;
    if (catalog) {
      catalog.classList.add('ft-v31-style-catalog');
      const mode = localStorage.getItem(VIEW_MODE_KEY) || 'grid';
      document.documentElement.dataset.ftViewMode = mode;
    }

    const controlsRow = qsa('div,section,article').find((el) => {
      const t = textOf(el);
      return t.includes('На экране') && (/6|9|12/.test(t));
    });

    if (!controlsRow || qs('.ft-v31-view-switch')) return;

    const switcher = document.createElement('div');
    switcher.className = 'ft-v31-view-switch';
    switcher.innerHTML = `
      <button type="button" data-mode="grid">▦</button>
      <button type="button" data-mode="comfort">◫</button>
      <button type="button" data-mode="list">≣</button>
    `;

    switcher.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-mode]');
      if (!btn) return;
      const mode = btn.dataset.mode;
      localStorage.setItem(VIEW_MODE_KEY, mode);
      document.documentElement.dataset.ftViewMode = mode;
      updateSwitcherState();
    });

    controlsRow.prepend(switcher);

    function updateSwitcherState() {
      const mode = localStorage.getItem(VIEW_MODE_KEY) || 'grid';
      switcher.querySelectorAll('[data-mode]').forEach((b) => {
        b.classList.toggle('is-active', b.dataset.mode === mode);
      });
    }

    updateSwitcherState();
  }

  function addSwipeHint() {
    if (qs('.ft-v31-swipe-hint')) return;
    const catalog = qs('.ft-v31-style-catalog');
    if (!catalog) return;

    const hint = document.createElement('div');
    hint.className = 'ft-v31-swipe-hint';
    hint.textContent = 'Листайте карточки и меняйте режим отображения';
    catalog.parentElement?.insertBefore(hint, catalog);
  }

  function fixProfileHeaderGradientLeak() {
    qsa('div,section,article').forEach((el) => {
      const t = textOf(el);
      if (/@guest-|Личный кабинет FOT AI/.test(t)) {
        el.classList.add('ft-v31-profile-shell');
      }
    });
  }

  function lockAdminTabForNonAdmin() {
    const isAdmin = Boolean(window.__FT_USER_IS_ADMIN__);
    qsa('button,a,div').forEach((el) => {
      const t = textOf(el);
      if (t === 'Админ' && !isAdmin) {
        el.style.display = 'none';
      }
    });
  }

  function enhanceAll() {
    document.documentElement.dataset.ftCompact = '1';
    removeDeployBadge();
    removeDuplicateCounter();
    injectGuestOrTelegramGate();
    placeAvatar();
    fixNotificationSummaryMargin();
    addRedProblemNotice();
    ensureAvitoLink();
    hideStaleHomeResult();
    markStyleCardsAndCompactView();
    addSwipeHint();
    fixProfileHeaderGradientLeak();
    lockAdminTabForNonAdmin();
  }

  const boot = () => requestAnimationFrame(enhanceAll);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }

  new MutationObserver(() => {
    clearTimeout(window.__ftV31Tick);
    window.__ftV31Tick = setTimeout(enhanceAll, 90);
  }).observe(document.documentElement, {
    subtree: true,
    childList: true,
  });
})();
