          <button type="button" class="ft-v31-entry-btn ft-v31-entry-btn-primary" data-action="guest">Я гость</button>
          <button type="button" class="ft-v31-entry-btn" data-action="telegram">Открыть через Telegram</button>
        </div>

        <div class="ft-v31-entry-note">В Telegram можно использовать фото профиля или переключиться на emoji-аватар позже.</div>
      </div>
    `;

    overlay.addEventListener('click', (e) => {
      const emojiBtn = e.target.closest('[data-emoji]');
      if (emojiBtn) {
        localStorage.setItem(AVATAR_EMOJI_KEY, emojiBtn.dataset.emoji || '✨');
        localStorage.setItem(AVATAR_GRADIENT_KEY, localStorage.getItem(AVATAR_GRADIENT_KEY) || 'lime');
        overlay.querySelectorAll('[data-emoji]').forEach((b) => b.classList.remove('is-active'));
        emojiBtn.classList.add('is-active');
        return;
      }

      const actionBtn = e.target.closest('[data-action]');
      if (!actionBtn) return;

      const action = actionBtn.dataset.action;
      if (action === 'guest') {
        const user = getStoredGuest() || buildGuestUser();
        user.avatarEmoji = localStorage.getItem(AVATAR_EMOJI_KEY) || user.avatarEmoji || '✨';
        user.avatarGradient = localStorage.getItem(AVATAR_GRADIENT_KEY) || user.avatarGradient || 'lime';
        saveGuestUser(user);
        localStorage.setItem(ENTRY_KEY, 'ready');
        overlay.remove();
        requestAnimationFrame(enhanceAll);
        return;
      }

      if (action === 'telegram') {
        if (isTelegramEnv()) {
          localStorage.setItem(ENTRY_KEY, 'ready');
          overlay.remove();
          requestAnimationFrame(enhanceAll);
          return;
        }

        window.location.href = BOT_URL;
      }
    });

    document.body.appendChild(overlay);
  }

